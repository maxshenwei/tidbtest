# Real TiDB test cases from: pingcap/tidb/tests/integrationtest/t/select.test
# Curated subset covering basic SELECT, LIMIT, JOIN, expressions.

DROP TABLE IF EXISTS t;
CREATE TABLE t (
 c1 int,
 c2 int,
 c3 int,
 PRIMARY KEY (c1)
);
INSERT INTO t VALUES (1,2,3);

# Basic SELECT variations
SELECT * from t;
SELECT c1, c2, c3 from t;
SELECT c1, c1 from t;
SELECT c1 as a, c2 as a from t;

# Literal selects
SELECT 1;
SELECT 1, 1;

# System/user variables
SET @@autocommit = 1;
SELECT @@autocommit;
SET @a = 10;
SET @b = 11;
SELECT @a, @@autocommit;
SELECT @a, @b;
SELECT 1, @a;
SET @b = "123";
SELECT @b + "123";
SELECT 1 + 1;

# Aliasing
SELECT 1 a, 1 as a, 1 + 1 a;
SELECT c1 a, c1 as a from t;

# LIMIT syntax variations
SELECT * from t LIMIT 0,1;
SELECT * from t LIMIT 1;
SELECT * from t LIMIT 1,1;
SELECT * from t LIMIT 1 OFFSET 0;

# Multi-table and JOIN
DROP TABLE IF EXISTS t2;
CREATE TABLE t2 (
 c1 int,
 c2 int,
 PRIMARY KEY (c1)
);
INSERT INTO t2 VALUES (1,2);
SELECT * from t a;
SELECT * from t a, t2 b;
SELECT * from t as a, t2 as b;
SELECT * from t a left join t2 b on a.c1 = b.c1;

# Duplicate column in derived table should fail
--error 1060
SELECT * from (SELECT 1, 1) as a;

--error 1060
SELECT * from (SELECT * FROM t, t2) as a;

# Boolean expressions
DROP TABLE IF EXISTS t;
CREATE TABLE t (c1 INT, c2 INT);
INSERT INTO t VALUES (1, 2), (1, 1), (1, 3);
SELECT c1=c2 FROM t;
SELECT 1=1;

# Arithmetic in SELECT
SELECT t.c1 + t.c2 from t limit 1;
SELECT t.c1 from t limit 1;
SELECT c1 + 10 from t limit 1;

# ALL / DISTINCT keywords
SELECT all c1, c2 from t limit 1;
SELECT distinct c1, c2 from t order by c1, c2 limit 1;

# NOT operator
SELECT c2 from t where not (c2 > 2);

# Unary plus/minus
select + - 1, --1, +-+-+1, + "123";
select --------------------1, ++++++++++++++++++++1;

# WHERE with static conditions
select * from t where null;
select * from t where 1;
select * from t where 0;
select * from t where null is not null;
select * from t where !1;

# Cross join variants
DROP TABLE IF EXISTS t2;
CREATE TABLE t2 (c1 int, c2 int, PRIMARY KEY (c1));
INSERT INTO t2 VALUES (1,2);
select * from t as a, t2 as b;
select * from t as a cross join t2 as b;
select * from t as a join t2 as b;
select * from t as a join t2 as b on a.c2 = b.c2;

# Table in parentheses
select * from (t);

# Precise numeric types — Issue 21692
drop table if exists precise_types;
create table precise_types (
 a BIGINT UNSIGNED NOT NULL,
 b BIGINT NOT NULL,
 c DECIMAL(21,1) NOT NULL,
 d DOUBLE(21,1) NOT NULL
);
insert into precise_types values (
 18446744073709551614,
 -9223372036854775806,
 99999999999999999999,
 18446744073709551614
);
SELECT a, b, c, d FROM precise_types;
